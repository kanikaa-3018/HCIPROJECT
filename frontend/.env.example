# Frontend Environment Variables Template

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# App Configuration
VITE_APP_NAME=Mess Menu & Feedback System
VITE_APP_ENV=development

# Notes for Production:
# - Change VITE_API_BASE_URL to your production API endpoint (e.g., https://api.yourdomain.com/api)
# - Change VITE_APP_ENV to 'production'
# - For Production, create a .env.production file with these values
# - Development uses .env file (default)
